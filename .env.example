# ── Database ──────────────────────────────────────────────────────────────────
# Supabase session pooler connection string.
DATABASE_URL="postgresql://postgres.<project-id>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?connection_limit=5"

# ── Encryption ────────────────────────────────────────────────────────────────
# 32-character key for AES-256-GCM encryption of stored API keys.
# NEVER rotate this without first decrypting and re-encrypting all stored secrets.
ENCRYPTION_KEY="your-32-character-secret-key-here"

# ── Authentication (Phase 2) ──────────────────────────────────────────────────
# JWT signing secret — must be at least 32 characters.
# Rotation procedure: update this value → all active sessions are invalidated → users must re-login.
# Store in a secrets manager (not this file) in production.
JWT_SECRET="your-32-plus-character-jwt-secret-here"

# JWT token lifetime (default: 8h). Valid values: "1h", "8h", "24h", "7d".
ACCESS_TOKEN_EXPIRY="8h"

# Set to "true" to allow POST /api/auth/register.
# DISABLE THIS after the first user is created to prevent open registration.
ALLOW_REGISTRATION="true"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# Production domain — add to CORS allowed origins when deploying behind a reverse proxy.
# Example: FRONTEND_URL="https://yourdomain.com"
FRONTEND_URL=""

# ── Limits ────────────────────────────────────────────────────────────────────
# Maximum requirement text length in characters (default: 50000).
MAX_REQUIREMENT_CHARS=50000
