{
  "name": "tracelms-cloud",
  "displayName": "TraceLMs Cloud",
  "description": "AI-powered test generation and Jira/Xray workflow — web-based SaaS platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "ts-node src/server.ts",
    "dev:watch": "nodemon --exec ts-node src/server.ts --ext ts",
    "build:backend": "esbuild src/server.ts --bundle --platform=node --format=cjs --outfile=dist/server.js --external:mammoth --external:pdf-parse",
    "build:frontend": "npm --prefix frontend run build",
    "build": "npm run build:backend && npm run build:frontend",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "typecheck:frontend": "npm --prefix frontend run typecheck",
    "typecheck:all": "npm run typecheck && npm run typecheck:frontend",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"frontend/src/**/*.{ts,tsx}\" --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"frontend/src/**/*.{ts,tsx}\" --fix",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "validate:prompts": "node scripts/validate-prompts.cjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "docx": "^9.7.1",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.14.2",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "esbuild": "^0.23.0",
    "eslint": "^8.57.1",
    "jest": "^29.5.0",
    "nodemon": "^3.1.4",
    "npm-run-all": "^4.1.5",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  }
}
