generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum OrgRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum ProjectRole {
  LEAD
  EDITOR
  REVIEWER
  VIEWER
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum GenerationStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
  PARTIAL
}

enum ApprovalConsensus {
  ANY
  ALL
}

enum PromptStep {
  ENHANCEMENT
  SCENARIOS
  TEST_CASES
  AUTOMATION
}

// ─── Users ────────────────────────────────────────────────────────────────────
// Single-user origin — first registered user is auto-assigned OWNER.
// All others default to EDITOR to avoid accidental lockout.

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  role         OrgRole         @default(EDITOR)
  isActive     Boolean         @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime        @default(now())
  settings     Settings?
  generations  Generation[]
  projects     Project[]
  members      ProjectMember[]

  @@index([role])
}

// ─── App Settings ────────────────────────────────────────────────────────────
// One row per user — scoped in Phase 3. The legacy global row (id='global')
// is claimed by the first authenticated user on first settings load.

model Settings {
  id               String   @id @default(cuid())
  userId           String?  @unique           // FK to User; claimed on first load
  user             User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  llmProvider      String   @default("Gemini")
  llmModel         String   @default("")
  llmApiKeyEnc     String   @default("") // encrypted
  jiraUrl          String   @default("")
  jiraProjectKey   String   @default("")
  jiraEmail        String   @default("")
  jiraApiTokenEnc  String   @default("") // encrypted
  xrayClientId     String   @default("")
  xrayClientSecEnc String   @default("") // encrypted
  xrayBatchSize    Int      @default(10)
  xrayBatchDelayMs Int      @default(1000)
  xrayMaxRetries   Int      @default(3)
  updatedAt        DateTime @updatedAt
}

// ─── LLM Providers ───────────────────────────────────────────────────────────

model LLMProvider {
  id            String      @id @default(cuid())
  name          String      @unique
  displayLabel  String
  baseUrl       String
  authHeader    String      @default("Bearer")
  apiKeyEnc     String      @default("")
  compatibility String      @default("openai")
  isBuiltIn     Boolean     @default(false)
  isActive      Boolean     @default(true)
  models        LLMModel[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model LLMModel {
  id           String      @id @default(cuid())
  modelId      String
  displayLabel String
  isDefault    Boolean     @default(false)
  provider     LLMProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId   String
  createdAt    DateTime    @default(now())

  @@unique([providerId, modelId])
}

// ─── Projects ─────────────────────────────────────────────────────────────────

model Project {
  id              String          @id @default(cuid())
  name            String
  key             String          @unique
  description     String          @default("")
  jiraProjectKey  String          @default("")
  status          ProjectStatus   @default(ACTIVE)
  owner           String          @default("")
  ownerId         String?
  userOwner       User?           @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  members         ProjectMember[]
  generations     Generation[]
  approvalLayers  ApprovalLayer[]
  promptTemplates PromptTemplate[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([ownerId])
  @@index([status])
}

// ─── Approval Chain ───────────────────────────────────────────────────────────
// Each project has up to 5 ordered approval layers.
// consensus=ANY: first approval in the layer advances to the next layer.
// consensus=ALL: every member in the layer must approve before advancing.

model ApprovalLayer {
  id        String              @id @default(cuid())
  project   Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  order     Int                 // 1–5
  consensus ApprovalConsensus   @default(ALL)
  members   ApprovalLayerMember[]
  createdAt DateTime            @default(now())

  @@unique([projectId, order])
  @@index([projectId])
}

model ApprovalLayerMember {
  id      String        @id @default(cuid())
  layer   ApprovalLayer @relation(fields: [layerId], references: [id], onDelete: Cascade)
  layerId String
  name    String        @default("")
  email   String

  @@index([layerId])
}

// ProjectMember replaces the Phase 3 Stakeholder model.
// Role is now a typed enum enforced by permissions middleware.

model ProjectMember {
  id          String      @id @default(cuid())
  email       String
  name        String      @default("")
  projectRole ProjectRole @default(VIEWER)
  userId      String?     // FK to User account (nullable — external stakeholders may not have accounts)
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  createdAt   DateTime    @default(now())

  @@unique([projectId, email])
  @@index([userId])
  @@index([projectId])
}

// ─── Generations ─────────────────────────────────────────────────────────────

model Generation {
  id               String           @id @default(cuid())
  project          Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId        String?
  userId           String?
  user             User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  requirementText  String
  llmProvider      String
  llmModel         String
  status           GenerationStatus @default(COMPLETED)
  enhancement      Json?
  scenarios        Json?
  testCases        Json?
  automation       Json?
  totalTestCases   Int              @default(0)
  totalScenarios   Int              @default(0)
  promptTokens     Int              @default(0)
  completionTokens Int              @default(0)
  totalTokens      Int              @default(0)
  xrayPushStatus   String?
  documents        Json?
  pushRecords      PushRecord[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([userId])
  @@index([projectId])
  @@index([createdAt])
  @@index([status])
}

// ─── Prompt Templates ─────────────────────────────────────────────────────────
// Editable LLM system prompts. step=null means global/auxiliary; typed steps
// map to the 4 main generation steps. isDefault=true rows are the seed baselines
// and cannot be deleted — only content can be overridden via isActive=false + new row.

model PromptTemplate {
  id        String     @id @default(cuid())
  name      String
  step      PromptStep
  content   String
  isDefault Boolean    @default(false)
  isActive  Boolean    @default(true)
  projectId String?
  project   Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([step])
  @@index([isActive])
  @@index([projectId])
}

// ─── Testimonials ─────────────────────────────────────────────────────────────
// Seeded by the admin via Prisma Studio or a seed script.
// isVisible: false hides the entry without deleting it.
// displayOrder controls left-to-right logo row ordering.

model Testimonial {
  id           String   @id @default(cuid())
  companyName  String
  logoUrl      String   @default("")  // absolute URL or path under /public
  quote        String   @default("")
  authorName   String   @default("")
  authorTitle  String   @default("")
  isVisible    Boolean  @default(false) // hidden until admin approves
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isVisible, displayOrder])
}

// ─── Push History ─────────────────────────────────────────────────────────────

model PushRecord {
  id           String      @id @default(cuid())
  fingerprint  String      @unique
  xrayKey      String
  xrayUrl      String
  pushedAt     DateTime    @default(now())
  generationId String?
  generation   Generation? @relation(fields: [generationId], references: [id], onDelete: SetNull)

  @@index([generationId])
}
